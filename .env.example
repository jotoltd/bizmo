# ==========================================
# Bizno Environment Variables
# Copy this file to .env.local and fill in your values
# ==========================================

# Supabase Configuration (Required)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site Configuration (Required)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For production: NEXT_PUBLIC_SITE_URL=https://bizno.co.uk

# Email Configuration (Required for production)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@bizno.co.uk

# Security (Required for production)
# Generate a random string: openssl rand -base64 32
CRON_SECRET=your-cron-secret-key

# ==========================================
# Optional Configuration
# ==========================================

# Sentry Error Tracking (Optional but recommended)
# Get DSN from: https://sentry.io/settings/projects/YOUR_PROJECT/keys/
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Apple Push Notification Service (Optional - for iOS push notifications)
APNS_TEAM_ID=YOUR_TEAM_ID
APNS_KEY_ID=YOUR_KEY_ID
APNS_BUNDLE_ID=com.bizno.app
# Paste the entire private key including BEGIN/END lines
APNS_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nMIG...\n-----END EC PRIVATE KEY-----"

# ==========================================
# Development Only
# ==========================================

# Enable debug logging (Optional)
DEBUG=false
